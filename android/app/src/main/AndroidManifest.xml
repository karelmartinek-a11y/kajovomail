<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="cz.kajovomail">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="KajovoMail"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true">
        <activity android:name="cz.kajovomail.MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
