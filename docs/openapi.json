{
  "openapi": "3.0.3",
  "info": {
    "title": "KajovoMail API",
    "version": "0.1.0",
    "description": "Core backend API for KajovoMail (/api/v1)."
  },
  "paths": {
    "/api/v1/health/live": {
      "get": {
        "responses": {
          "200": {
            "description": "Liveness check"
          }
        }
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "responses": {
          "200": {
            "description": "Readiness check"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "Authenticate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session token"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SessionCreate": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}
